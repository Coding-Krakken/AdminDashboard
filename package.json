{
  "name": "@universal-admin/workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:saas": "npm run typecheck -w @universal-admin/saas-next",
    "test": "vitest run",
    "test:saas": "vitest run -c apps/saas-next/vitest.config.ts",
    "verify:config": "node ./scripts/verify-config.mjs",
    "verify:generated": "node ./scripts/verify-generated-modules.mjs",
    "verify:plugins": "node ./scripts/verify-plugins.mjs",
    "verify:saas-smoke": "node ./scripts/verify-saas-smoke.mjs",
    "verify:plug-and-play": "node ./scripts/verify-plug-and-play-readiness.mjs",
    "bootstrap:plug-and-play": "node ./scripts/bootstrap-plug-and-play.mjs",
    "verify:migration-readiness": "node ./scripts/verify-migration-readiness.mjs",
    "migrate:backfill-runtime": "node ./scripts/backfill-runtime-state.mjs --dry-run",
    "verify:admin-policy": "node ./scripts/verify-admin-api-policy.mjs",
    "dev:starter": "npm run dev -w @universal-admin/starter-next",
    "dev:saas": "npm run dev -w @universal-admin/saas-next",
    "db:generate": "npm run db:generate -w @universal-admin/saas-next",
    "db:migrate": "npm run db:migrate -w @universal-admin/saas-next",
    "db:push": "npm run db:push -w @universal-admin/saas-next",
    "db:seed": "npm run db:seed -w @universal-admin/saas-next",
    "scaffold:module": "universal-admin create-module"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "baseline-browser-mapping": "^2.10.32",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
