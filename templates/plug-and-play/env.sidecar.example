# Universal Admin Sidecar Environment Example

# Business profile: generic | field-service | saas | commerce
ADMIN_BUSINESS_PROFILE=generic

# Public mount path used by sidecar route generation and static assets
ADMIN_PUBLIC_BASE_PATH=/admin

# Auth provider: memory | nextauth | clerk | jwt | anonymous
ADMIN_AUTH_PROVIDER=memory

# Memory-auth fallback identity (dev only)
ADMIN_AUTH_USER_ID=dev-admin
ADMIN_AUTH_ROLE=admin
ADMIN_AUTH_EMAIL=admin@localhost

# Optional
ADMIN_AUTH_TENANT_ID=tenant-demo
ADMIN_AUTH_PERMISSIONS=dashboard:read,settings:read,settings:write,audit:read

# Optional host-brand theme overrides
# ADMIN_HOST_THEME_JSON={"dashboard-accent":"#f5b400"}
# ADMIN_HOST_THEME_FILE=.admin-dashboard-kit/theme.tokens.json
