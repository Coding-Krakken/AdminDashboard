# SaaS local development environment
# Usage: cp apps/saas-next/.env.local.example apps/saas-next/.env.local

# Required: database connections used by Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/admin_dashboard"
DIRECT_URL="postgresql://user:password@localhost:5432/admin_dashboard"

# Required: bearer secret for platform provisioning APIs
PLATFORM_ADMIN_SECRET="replace-with-a-long-random-secret"

# Optional: local overrides for platform API rate limiting
PLATFORM_API_RATE_LIMIT_MAX="120"
PLATFORM_API_RATE_LIMIT_WINDOW_MS="60000"

# Optional: enables programmatic Vercel domain management
# Leave unset to use fallback/manual domain verification instructions.
VERCEL_API_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""

# Optional: default base URL for scripts/verify-saas-smoke.mjs
SAAS_BASE_URL="http://localhost:3000"