# SaaS Multi-Tenant Environment Variables
# Preferred local template: apps/saas-next/.env.local.example
# This file remains as a compatibility example.

# Database (Vercel Postgres / Neon)
DATABASE_URL="postgresql://user:password@localhost:5432/admin_dashboard"
DIRECT_URL="postgresql://user:password@localhost:5432/admin_dashboard"

# Platform admin secret (used to authenticate provisioning API calls)
PLATFORM_ADMIN_SECRET="change-me-to-a-secure-random-string"

# Platform API rate limiting
# Maximum requests per source IP + scope in a rolling window
PLATFORM_API_RATE_LIMIT_MAX="120"
# Window size in milliseconds
PLATFORM_API_RATE_LIMIT_WINDOW_MS="60000"

# Optional: Vercel API token for programmatic domain management
VERCEL_API_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""

# Optional: default base URL for scripts/verify-saas-smoke.mjs
SAAS_BASE_URL="http://localhost:3000"
