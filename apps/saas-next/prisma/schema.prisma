generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  config  TenantConfig?
  theme   TenantTheme?
  domains TenantDomain[]
  runtimeState RuntimeState[]

  @@index([slug])
  @@index([status])
}

model TenantConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  dashboardConfig Json
  authProvider    String   @default("platform")
  authConfig      Json     @default("{}")
  businessProfile String   @default("generic")
  preferredAccessStrategy AccessStrategy @default(DOMAIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TenantTheme {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  tokens     Json   @default("{}")
  logoUrl    String?
  faviconUrl String?
  darkMode   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TenantDomain {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  domain         String  @unique
  verified       Boolean @default(false)
  vercelDomainId String?
  isPrimary      Boolean @default(false)
  accessStrategy AccessStrategy @default(DOMAIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([domain])
}

model RuntimeState {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  key   String
  value Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
}

model AuditLog {
  id       String @id @default(cuid())
  tenantId String

  actorId  String
  action   String
  entity   String
  entityId String
  metadata Json?

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([actorId])
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PROVISIONING
}

enum AccessStrategy {
  DOMAIN
  API_ALIAS
  BOTH
}
